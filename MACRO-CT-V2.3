show_vol    = input.bool(true, "Show Volume Rotation", group=grp_toggles, tooltip="Institutional money flow and volume spikes.")

// ==============================================================================
// 2. MODULE-SPECIFIC SETTINGS
// ==============================================================================
grp_idx = "3. Index Trend"
idx_sym     = input.symbol("SPY", "Market Index Ticker", group=grp_idx)
idx_smaLen  = input.int(200, "SMA Length for Bull/Bear", group=grp_idx, tooltip="The primary moving average used to determine macro Bull or Bear regimes.")
idx_chopPer = input.int(14, "Chop Index Period", group=grp_idx)
idx_chopC   = input.float(61.8, "Chop: Chaos Threshold", group=grp_idx, step=0.1, tooltip="Above this value, the market is completely untradable (Red).")
idx_chopT   = input.float(50.0, "Chop: Transition Threshold", group=grp_idx, step=0.1, tooltip="Between this and Trending, the market is choppy/transitioning (Orange).")
idx_chopTr  = input.float(38.2, "Chop: Trending Threshold", group=grp_idx, step=0.1, tooltip="Below this value, the market is in a clean, tradable trend (Green).")
htf_tf      = input.timeframe("1W", "HTF Confirmation Timeframe", group=grp_idx)
htf_emaLen  = input.int(20, "HTF EMA Length", group=grp_idx, tooltip="The moving average used for the Higher Timeframe (HTF) Weekly check.")

grp_brd = "4. Sector Breadth"
brd_tf      = input.timeframe("W", "Breadth Macro Timeframe", group=grp_brd, tooltip="The timeframe used to calculate the broader Breadth phases (Rp, Tu, Tp, Cr).")
vol_tf_D    = input.timeframe("D", "Secondary Volume Timeframe (Daily)", group=grp_brd, tooltip="The timeframe used for daily volume spike detection.")
brd_vLen    = input.int(12, "Velocity Length (ROC period)", group=grp_brd)
brd_aLen    = input.int(3, "Base Acceleration Length", group=grp_brd)
brd_volW    = input.bool(true, "Include Volume Weight in Score", group=grp_brd, tooltip="If true, sectors with massive volume spikes are weighted more heavily in the Breadth Score.")
brd_volAvg  = input.int(20, "Volume Average Period (days)", group=grp_brd)
brd_volThr   = input.float(1.3, "Volume Spike Threshold - Weekly (x avg)", group=grp_brd, step=0.1, tooltip="1.3 = 130% of average volume. Triggers the weekly institutional accumulation tracker.")
brd_volThr_D = input.float(1.1, "Volume Spike Threshold - Daily (x avg)", group=grp_brd, step=0.1, tooltip="1.1 = 110% of average volume. Triggers the daily SPDR tracker.")

grp_reg = "5. Factor Regime"
reg_rocLen  = input.int(14, "ROC Period for Regime", group=grp_reg, tooltip="Lookback period to measure Factor momentum against each other.")

grp_corr = "6. Implied Correlation"
cor_tf      = input.timeframe("240", "Implied Corr Timeframe", group=grp_corr)
cor_len     = input.int(14, "Correlation Length", group=grp_corr)
cor_kFast   = input.int(7, "KAMA Fast Period", group=grp_corr)
cor_kSlow   = input.int(19, "KAMA Slow Period", group=grp_corr)
cor_kER     = input.int(8, "KAMA Efficiency Ratio Period", group=grp_corr)
cor_kNorm   = input.int(10, "KAMA Normalization Lookback", group=grp_corr)
cor_thr     = input.float(0.0, "ImplCorr Green Threshold", group=grp_corr, step=0.1, tooltip="The correlation value required to trigger a 'First Green' alignment signal.")

grp_mmfi = "7. MMFI"
mmf_sLen    = input.int(10, "MMFI Short MA", group=grp_mmfi)
mmf_lLen    = input.int(50, "MMFI Long MA", group=grp_mmfi)

grp_vix = "8. VIX"
vix_sLen    = input.int(10, "VIX Short MA", group=grp_vix, tooltip="Used to determine if Volatility is expanding (price above MA) or contracting (price below MA).")
vix_bbLen   = input.int(20, "VIX Bollinger Length", group=grp_vix)
vix_bbStd   = input.float(2.0, "VIX Bollinger StdDev", group=grp_vix, step=0.1)
vix_elev    = input.float(20.0, "VIX Elevated Threshold", group=grp_vix, step=1.0)
vix_fear    = input.float(30.0, "VIX Fear Threshold", group=grp_vix, step=1.0)
vix_extr    = input.float(40.0, "VIX Extreme Threshold", group=grp_vix, step=1.0, tooltip="Contrarian panic zone. Historically signals market bottoms.")

grp_colors = "9. Dashboard Colors"
dash_bg_col = input.color(color.black, "Dashboard Background", group=grp_colors)
dash_transp = input.int(15, "Dashboard Transparency (0=Solid, 100=Invisible)", minval=0, maxval=100, group=grp_colors)
col_bull    = input.color(#0F6E56, "Bullish Color (Green)", group=grp_colors)
col_bear    = input.color(#A32D2D, "Bearish Color (Red)", group=grp_colors)
col_warn    = input.color(#854F0B, "Warning Color (Orange)", group=grp_colors)
col_neut    = input.color(#185FA5, "Neutral Color (Blue)", group=grp_colors)
col_head_bg = input.color(#424242, "Header Background Color", group=grp_colors)
col_head_txt= input.color(color.white, "Header Text Color", group=grp_colors)
col_lbl_txt = input.color(color.white, "Row Label Text Color", group=grp_colors)

// ==============================================================================
// 3. ETF UNIVERSES
// ==============================================================================
syms = array.from(
    "XLK", "XLV", "XLF", "XLE", "XLI", "XLY", "XLP", "XLU", "XLB", "XLC", "XLRE",
    "SMH", "IGV", "XBI", "IBB", "KRE", "XOP", "XHB", "ITA", "JETS", "GDX", "URA",
    "TAN", "IBIT", "TLT", "GRID", "QTUM")

spdr_syms = array.from("XLK", "XLV", "XLF", "XLE", "XLI", "XLY", "XLP", "XLU", "XLB", "XLC", "XLRE")

// ==============================================================================
// 4. MODULE 1: INDEX TREND & REGIME
// ==============================================================================
f_chopIndex() =>
    _atrSum = math.sum(ta.atr(1), idx_chopPer)
    _range = ta.highest(high, idx_chopPer) - ta.lowest(low, idx_chopPer)
    _range := _range == 0 ? 1 : _range
    100 * math.log10(_atrSum / _range) / math.log10(idx_chopPer)

[spy_close, spy_sma200, spy_chop, spy_ema21, spy_sma50, spy_sma150] = request.security(idx_sym, "D", [close, ta.sma(close, idx_smaLen), f_chopIndex(), ta.ema(close, 21), ta.sma(close, 50), ta.sma(close, 150)])
[htf_close, htf_ema] = request.security(syminfo.tickerid, htf_tf, [close, ta.ema(close, htf_emaLen)])
htfBullish = htf_close > htf_ema

// Chop state (separate from trend — measures trending vs ranging)
string chop_state = "SUPER TREND"
if spy_chop > idx_chopC
    chop_state := "CHOP/CHAOS"
else if spy_chop > idx_chopT
    chop_state := "TRANSITION"
else if spy_chop > idx_chopTr
    chop_state := "TRENDING"

// SPY Trend Context (where price sits in the MA stack)
string spy_trend = "BEAR"
color spy_trend_col = col_bear
float idx_score = 0

if spy_close < spy_sma200
    spy_trend := "BEAR"
    spy_trend_col := col_bear
    idx_score := 0
else if spy_close < spy_sma50
    spy_trend := "DEEP PULLBACK"
    spy_trend_col := col_warn
    idx_score := 35
else if spy_close < spy_ema21
    spy_trend := "PULLBACK"
    spy_trend_col := col_neut
    idx_score := 60
else if spy_ema21 > spy_sma50 and spy_sma50 > spy_sma150 and spy_sma150 > spy_sma200
    spy_trend := "POWER TREND"
    spy_trend_col := col_bull
    idx_score := 100
else
    spy_trend := "UPTREND"
    spy_trend_col := col_bull
    idx_score := 75

// ==============================================================================
// 5. MODULE 2: SECTOR BREADTH & LIQUIDITY
// ==============================================================================
float tnx_change = request.security("TNX", timeframe.period, ta.change(close), ignore_invalid_symbol=true)
bool liquidity_stress = nz(tnx_change) > 0

float rip_c = 0.0, float trn_c = 0.0, float top_c = 0.0, float crs_c = 0.0
int hot_total = 0
string[] hot_syms = array.new_string()
float[] hot_vols = array.new_float()
string[] hot_dirs = array.new_string()

int hot_total_D = 0
string[] hot_syms_D = array.new_string()
float[] hot_vols_D = array.new_float()
string[] hot_dirs_D = array.new_string()

f_breadth_calc(vLen, aLen, vAvg) =>
    v = ta.roc(close, vLen)
    a = ta.change(v, aLen)
    vr = volume / math.max(1, ta.sma(volume, vAvg))
    [v, a, vr]

// 1. Weekly Breadth Engine (27 ETFs)
for i = 0 to array.size(syms) - 1
    string s = array.get(syms, i)
    [vel, acc, vol_ratio] = request.security(s, brd_tf, f_breadth_calc(brd_vLen, brd_aLen, brd_volAvg), ignore_invalid_symbol=true)
    
    int phase = (vel > 0 and acc > 0) ? 4 : (vel <= 0 and acc > 0) ? 3 : (vel > 0 and acc < 0) ? 2 : 1
    float w = (brd_volW and vol_ratio > brd_volThr) ? 1.5 : 1.0
    
    if phase == 4
        rip_c += w
    else if phase == 3
        trn_c += w
    else if phase == 2
        top_c += w
    else
        crs_c += w
        
    // Weekly Hot Sectors
    if vol_ratio > brd_volThr
        hot_total += 1
        string dir = vel > 0 ? "▲" : vel < 0 ? "▼" : "◼"
        array.push(hot_syms, s)
        array.push(hot_vols, vol_ratio)
        array.push(hot_dirs, dir)

// 2. Daily Volume Rotation (11 SPDR ETFs)
for i = 0 to array.size(spdr_syms) - 1
    string s_d = array.get(spdr_syms, i)
    [vel_d, acc_d, vol_ratio_d] = request.security(s_d, vol_tf_D, f_breadth_calc(brd_vLen, brd_aLen, brd_volAvg), ignore_invalid_symbol=true)
    
    // Daily Hot Sectors
    if vol_ratio_d > brd_volThr_D
        hot_total_D += 1
        string dir_d = vel_d > 0 ? "▲" : vel_d < 0 ? "▼" : "◼"
        array.push(hot_syms_D, s_d)
        array.push(hot_vols_D, vol_ratio_d)
        array.push(hot_dirs_D, dir_d)

// Volume Sorting Helper Function
f_sort_arrays(vols, syms, dirs) =>
    int sz = array.size(vols)
    if sz > 1
        for i = 0 to sz - 2
            for j = 0 to sz - i - 2
                if array.get(vols, j) < array.get(vols, j+1)
                    float tmp_v = array.get(vols, j)
                    array.set(vols, j, array.get(vols, j+1))
                    array.set(vols, j+1, tmp_v)
                    string tmp_s = array.get(syms, j)
                    array.set(syms, j, array.get(syms, j+1))
                    array.set(syms, j+1, tmp_s)
                    string tmp_d = array.get(dirs, j)
                    array.set(dirs, j, array.get(dirs, j+1))
                    array.set(dirs, j+1, tmp_d)

if barstate.islast
    f_sort_arrays(hot_vols, hot_syms, hot_dirs)
    f_sort_arrays(hot_vols_D, hot_syms_D, hot_dirs_D)

float total_brd = math.max(1, rip_c + trn_c + top_c + crs_c)
float raw_score = (rip_c * 2 + trn_c * 1 - top_c * 1 - crs_c * 2)
float brd_score = ((raw_score + 2 * total_brd) / (4 * total_brd)) * 100

float fast_breadth = (rip_c + trn_c) / total_brd

// ==============================================================================
// 6. MODULE 3 & 4: FACTOR REGIME & IMPLIED CORRELATION (15 ETFs)
// ==============================================================================
f_kama(asset) =>
    change = math.abs(asset - nz(asset[cor_kER]))
    volatility = math.sum(math.abs(asset - nz(asset[1])), cor_kER)
    er = volatility == 0 ? 0 : change / volatility
    sc = er * (2/(cor_kFast+1) - 2/(cor_kSlow+1)) + 2/(cor_kSlow+1)
    kama_val = ta.ema(asset, cor_kFast) + sc * (asset - ta.ema(asset, cor_kFast))
    lowest = ta.lowest(kama_val, cor_kNorm)
    highest = ta.highest(kama_val, cor_kNorm)
    normalized = highest == lowest ? 0 : (kama_val - lowest) / (highest - lowest) - 0.5
    normalized > 0 ? 1 : -1

float fc_SPHD = request.security("SPHD", cor_tf, close, ignore_invalid_symbol=true)
float fc_SPLV = request.security("SPLV", cor_tf, close, ignore_invalid_symbol=true)
float fc_QUAL = request.security("QUAL", cor_tf, close, ignore_invalid_symbol=true)
float fc_DEF  = request.security("DEF",  cor_tf, close, ignore_invalid_symbol=true)
float fc_IWF  = request.security("IWF",  cor_tf, close, ignore_invalid_symbol=true)
float fc_SPHB = request.security("SPHB", cor_tf, close, ignore_invalid_symbol=true)
float fc_IYT  = request.security("IYT",  cor_tf, close, ignore_invalid_symbol=true)
float fc_IWN  = request.security("IWN",  cor_tf, close, ignore_invalid_symbol=true)
float fc_IWD  = request.security("IWD",  cor_tf, close, ignore_invalid_symbol=true)
float fc_IWM  = request.security("IWM",  cor_tf, close, ignore_invalid_symbol=true)
float fc_IWR  = request.security("IWR",  cor_tf, close, ignore_invalid_symbol=true)
float fc_MGK  = request.security("MGK",  cor_tf, close, ignore_invalid_symbol=true)
float fc_OEF  = request.security("OEF",  cor_tf, close, ignore_invalid_symbol=true)
float fc_MTUM = request.security("MTUM", cor_tf, close, ignore_invalid_symbol=true)
float fc_IWB  = request.security("IWB",  cor_tf, close, ignore_invalid_symbol=true)

float roc_SPHD = ta.roc(fc_SPHD, reg_rocLen)
float roc_SPLV = ta.roc(fc_SPLV, reg_rocLen)
float roc_QUAL = ta.roc(fc_QUAL, reg_rocLen)
float roc_DEF  = ta.roc(fc_DEF,  reg_rocLen)
float roc_IWF  = ta.roc(fc_IWF,  reg_rocLen)
float roc_SPHB = ta.roc(fc_SPHB, reg_rocLen)
float roc_IYT  = ta.roc(fc_IYT,  reg_rocLen)
float roc_IWN  = ta.roc(fc_IWN,  reg_rocLen)
float roc_IWD  = ta.roc(fc_IWD,  reg_rocLen)
float roc_IWM  = ta.roc(fc_IWM,  reg_rocLen)
float roc_IWR  = ta.roc(fc_IWR,  reg_rocLen)
float roc_MGK  = ta.roc(fc_MGK,  reg_rocLen)
float roc_OEF  = ta.roc(fc_OEF,  reg_rocLen)
float roc_MTUM = ta.roc(fc_MTUM, reg_rocLen)
float roc_IWB  = ta.roc(fc_IWB,  reg_rocLen)

float avg_roc = nz((roc_SPHD + roc_SPLV + roc_QUAL + roc_DEF + roc_IWF + roc_SPHB + roc_IYT + roc_IWN + roc_IWD + roc_IWM + roc_IWR + roc_MGK + roc_OEF + roc_MTUM + roc_IWB) / 15)

float r_SPHD = roc_SPHD - avg_roc
float r_SPLV = roc_SPLV - avg_roc
float r_QUAL = roc_QUAL - avg_roc
float r_DEF  = roc_DEF  - avg_roc
float r_IWF  = roc_IWF  - avg_roc
float r_SPHB = roc_SPHB - avg_roc
float r_IYT  = roc_IYT  - avg_roc
float r_IWN  = roc_IWN  - avg_roc
float r_IWD  = roc_IWD  - avg_roc
float r_IWM  = roc_IWM  - avg_roc
float r_IWR  = roc_IWR  - avg_roc
float r_MGK  = roc_MGK  - avg_roc
float r_OEF  = roc_OEF  - avg_roc
float r_MTUM = roc_MTUM - avg_roc
float r_IWB  = roc_IWB  - avg_roc

float g_locs = (r_SPHB>0?1:0) + (r_IWM>0?1:0) + (r_MGK>0?1:0) + (r_IYT>0?1:0) + (r_IWN>0?1:0) + (r_IWR>0?1:0) + (r_SPLV<0?1:0) + (r_DEF<0?1:0) + (r_SPHD<0?1:0) + (r_QUAL<0?1:0) + (r_OEF<0?1:0)
float refla  = (r_SPHB>0?1:0) + (r_IWM>0?1:0) + (r_MGK>0?1:0) + (r_IYT>0?1:0) + (r_IWN>0?1:0) + (r_MTUM>0?1:0) + (r_SPLV<0?1:0) + (r_DEF<0?1:0) + (r_SPHD<0?1:0) + (r_QUAL<0?1:0) + (r_IWB<0?1:0)
float infla  = (r_SPLV>0?1:0) + (r_DEF>0?1:0) + (r_MGK>0?1:0) + (r_SPHD>0?1:0) + (r_QUAL>0?1:0) + (r_SPHB<0?1:0) + (r_IWM<0?1:0) + (r_IYT<0?1:0) + (r_IWN<0?1:0) + (r_IWR<0?1:0) + (r_IWD<0?1:0)
float defla  = (r_SPLV>0?1:0) + (r_DEF>0?1:0) + (r_MGK>0?1:0) + (r_SPHD>0?1:0) + (r_IWF>0?1:0) + (r_SPHB<0?1:0) + (r_IWM<0?1:0) + (r_IYT<0?1:0) + (r_IWN<0?1:0) + (r_IWR<0?1:0) + (r_IWD<0?1:0)

float total_reg = math.max(1, g_locs + refla + infla + defla)
bool risk_on = (g_locs > infla or g_locs > defla or refla > infla or refla > defla)

float reg_score = risk_on ? 80.0 : 20.0
reg_score := math.min(100, math.max(0, reg_score * (g_locs / total_reg + 0.5)))

float cor_SPHD = ta.correlation(close, fc_SPHD, cor_len)
float cor_SPLV = ta.correlation(close, fc_SPLV, cor_len)
float cor_QUAL = ta.correlation(close, fc_QUAL, cor_len)
float cor_DEF  = ta.correlation(close, fc_DEF,  cor_len)
float cor_IWF  = ta.correlation(close, fc_IWF,  cor_len)
float cor_SPHB = ta.correlation(close, fc_SPHB, cor_len)
float cor_IYT  = ta.correlation(close, fc_IYT,  cor_len)
float cor_IWN  = ta.correlation(close, fc_IWN,  cor_len)
float cor_IWD  = ta.correlation(close, fc_IWD,  cor_len)
float cor_IWM  = ta.correlation(close, fc_IWM,  cor_len)
float cor_IWR  = ta.correlation(close, fc_IWR,  cor_len)
float cor_MGK  = ta.correlation(close, fc_MGK,  cor_len)
float cor_OEF  = ta.correlation(close, fc_OEF,  cor_len)
float cor_MTUM = ta.correlation(close, fc_MTUM, cor_len)
float cor_IWB  = ta.correlation(close, fc_IWB,  cor_len)

float ImplCorrAvg = math.avg(
     cor_SPHD * f_kama(fc_SPHD), cor_SPLV * f_kama(fc_SPLV), cor_QUAL * f_kama(fc_QUAL),
     cor_DEF  * f_kama(fc_DEF),  cor_IWF  * f_kama(fc_IWF),  cor_SPHB * f_kama(fc_SPHB),
     cor_IYT  * f_kama(fc_IYT),  cor_IWN  * f_kama(fc_IWN),  cor_IWD  * f_kama(fc_IWD),
     cor_IWM  * f_kama(fc_IWM),  cor_IWR  * f_kama(fc_IWR),  cor_MGK  * f_kama(fc_MGK),
     cor_OEF  * f_kama(fc_OEF),  cor_MTUM * f_kama(fc_MTUM), cor_IWB  * f_kama(fc_IWB))

float corr_score = math.max(0, math.min(100, (ImplCorrAvg + 1) * 50))

// ==============================================================================
// 7. MODULE 5: MMFI
// ==============================================================================
[mmfi_c, mmfi_c1, mmfi_s10, mmfi_s50] = request.security("MMFI", "D", [close, close[1], ta.sma(close, mmf_sLen), ta.sma(close, mmf_lLen)], ignore_invalid_symbol=true)

string mmfi_zone = "NEUTRAL"
float mmfi_score = 50
if mmfi_c < 20
    mmfi_zone := "CAPITULATION", mmfi_score := 85
else if mmfi_c < 40
    mmfi_zone := "BEARISH", mmfi_score := 30
else if mmfi_c > 75
    mmfi_zone := "OVERHEATED", mmfi_score := 40
else if mmfi_c > 60
    mmfi_zone := "HEALTHY", mmfi_score := 75

bool mmfi_rising = mmfi_c > mmfi_c1
if mmfi_rising and mmfi_c > mmfi_s10 and mmfi_c > mmfi_s50
    mmfi_score += 10
else if not mmfi_rising and mmfi_c < mmfi_s10 and mmfi_c < mmfi_s50
    mmfi_score -= 10

// ==============================================================================
// 8. MODULE 6: VIX
// ==============================================================================
[vix_c, vix_s10, vix_bbM, vix_bbSt] = request.security("VIX", "D", [close, ta.sma(close, vix_sLen), ta.sma(close, vix_bbLen), ta.stdev(close, vix_bbLen)], ignore_invalid_symbol=true)
float vix_bbU = vix_bbM + (vix_bbStd * vix_bbSt)

string vix_zone = "COMPLACENT"
float vix_score = 70
string vix_act = "NO ACTION / TAKE PROFITS"
int vix_zone_code = 0

if vix_c > vix_extr
    vix_zone := "EXTREME", vix_score := 75, vix_act := "MAX HEDGE / PREPARE FOR REVERSAL", vix_zone_code := 3
else if vix_c > vix_fear
    vix_zone := "FEAR", vix_score := 60, vix_act := "HEDGE ACTIVE / LOOK FOR CAPIT", vix_zone_code := 2
else if vix_c > vix_elev
    vix_zone := "ELEVATED", vix_score := 45, vix_act := "REDUCE SIZE / TIGHTEN STOPS", vix_zone_code := 1

// ==============================================================================
// 9. COMPOSITE SCORE & ZONES
// ==============================================================================
float composite_score = (idx_score * 0.20) + (brd_score * 0.25) + (reg_score * 0.10) + (corr_score * 0.10) + (mmfi_score * 0.15) + (vix_score * 0.20)

string action_text = "CASH / HEDGE | B/O FAIL"
int action_code = 0
color action_col = color.red
if composite_score >= 80
    action_text := "AGGRESSIVE | B/O WORK", action_code := 4, action_col := #0F6E56
else if composite_score >= 60
    action_text := "FULL SIZE | B/O WORK", action_code := 3, action_col := #1D9B52
else if composite_score >= 40
    action_text := "HALF SIZE | THEME B/O", action_code := 2, action_col := #854F0B
else if composite_score >= 20
    action_text := "TRAPS ONLY | B/O FAIL", action_code := 1, action_col := #A32D2D

// ==============================================================================
// 10. RECOVERED METRICS & DELTAS
// ==============================================================================
// Breadth Thrust: Fast Breadth surges from < 30% to > 60% in 3 days
bool breadth_thrust = fast_breadth > 0.60 and nz(fast_breadth[3]) < 0.30
int bars_since_thrust = nz(ta.barssince(breadth_thrust))

// Correlation First Green: Crosses user-defined threshold
bool first_green = ImplCorrAvg > cor_thr and nz(ImplCorrAvg[1]) <= cor_thr
int bars_since_green = nz(ta.barssince(first_green))

// --- DELTAS & REGIME PCTS ---

// --- DELTAS & REGIME PCTS ---
float comp_delta = composite_score - nz(composite_score[1])
string comp_str = str.tostring(composite_score, "#.1") + (comp_delta >= 0 ? " (+" : " (") + str.tostring(comp_delta, "#.1") + ")"

float brd_delta = brd_score - nz(brd_score[1])
string brd_str = str.tostring(brd_score, "#.1") + (brd_delta >= 0 ? " (+" : " (") + str.tostring(brd_delta, "#.1") + ")"

float corr_delta = ImplCorrAvg - nz(ImplCorrAvg[1])
string corr_str = str.tostring(ImplCorrAvg, "#.2") + (corr_delta >= 0 ? " (+" : " (") + str.tostring(corr_delta, "#.2") + ")"

float mmfi_delta = mmfi_c - nz(mmfi_c[1])
string mmfi_str = str.tostring(mmfi_c, "#.1") + (mmfi_delta >= 0 ? " (+" : " (") + str.tostring(mmfi_delta, "#.1") + ")"

float vix_delta = vix_c - nz(vix_c[1])
string vix_str = str.tostring(vix_c, "#.2") + (vix_delta >= 0 ? " (+" : " (") + str.tostring(vix_delta, "#.2") + ")"

int hot_d_prev = nz(hot_total_D[1])
string hot_d_str = str.tostring(hot_total_D) + " / 11 (was " + str.tostring(hot_d_prev) + ")"

float g_pct = (g_locs / total_reg) * 100
float r_pct = (refla / total_reg) * 100
float i_pct = (infla / total_reg) * 100
float d_pct = (defla / total_reg) * 100
string reg_pct_str = "G:" + str.tostring(g_pct, "#") + " R:" + str.tostring(r_pct, "#") + " I:" + str.tostring(i_pct, "#") + " D:" + str.tostring(d_pct, "#")

// ==============================================================================
// 11. DASHBOARD TABLE
// ==============================================================================
f_getPos(y, x) =>
    string key = y + "_" + x
    switch key
        "top_left"      => position.top_left
        "top_center"    => position.top_center
        "top_right"     => position.top_right
        "middle_left"   => position.middle_left
        "middle_center" => position.middle_center
        "middle_right"  => position.middle_right
        "bottom_left"   => position.bottom_left
        "bottom_center" => position.bottom_center
        "bottom_right"  => position.bottom_right
        => position.bottom_center

int t_cols = dash_orient == "Vertical" ? 2 : 60
int t_rows = dash_orient == "Vertical" ? 40 : 4
var table dash = table.new(f_getPos(dash_y, dash_x), t_cols, t_rows, bgcolor=color.new(dash_bg_col, dash_transp), border_width=1, frame_color=color.gray, border_color=color.new(color.white, dash_transp + 10))

size_str = switch dash_size
    "Tiny"   => size.tiny
    "Small"  => size.small
    "Normal" => size.normal
    "Large"  => size.large
    => size.tiny

var h_col_ptr = array.new_int(1, 0)
f_write(int v_row, string lbl, string val, color bg_col) =>
    int current_h_col = array.get(h_col_ptr, 0)
    if dash_orient == "Vertical"
        table.cell(dash, 0, v_row, lbl, text_color=col_lbl_txt, text_size=size_str, text_halign=text.align_left)
        table.cell(dash, 1, v_row, val, text_color=color.white, bgcolor=bg_col, text_size=size_str, text_halign=text.align_right)
    else
        table.cell(dash, current_h_col, 0, lbl, text_color=col_lbl_txt, text_size=size_str, text_halign=text.align_center)
        table.cell(dash, current_h_col, 1, val, text_color=color.white, bgcolor=bg_col, text_size=size_str, text_halign=text.align_center)
        array.set(h_col_ptr, 0, current_h_col + 1)

if barstate.islast
    array.set(h_col_ptr, 0, 0)
    int row = 0
    color bg_G = color.new(col_bull, dash_transp)
    color bg_R = color.new(col_bear, dash_transp)
    color bg_A = color.new(col_warn, dash_transp)
    color bg_N = color.new(col_neut, dash_transp)

    if show_comp
        if dash_orient == "Vertical"
            table.merge_cells(dash, 0, row, 1, row)
            table.cell(dash, 0, row, "COMPOSITE SCORE", text_color=col_head_txt, bgcolor=color.new(col_head_bg, dash_transp), text_size=size_str)
            row += 1
        f_write(row, "Macro Score", comp_str, composite_score > 60 ? bg_G : composite_score < 40 ? bg_R : bg_A)
        row += 1
        f_write(row, "Action Zone", action_text, color.new(action_col, 50))
        row += 1

    if show_index
        if dash_orient == "Vertical"
            table.merge_cells(dash, 0, row, 1, row)
            table.cell(dash, 0, row, "INDEX TREND", text_color=col_head_txt, bgcolor=color.new(col_head_bg, dash_transp), text_size=size_str)
            row += 1
        f_write(row, "SPY Trend", spy_trend, color.new(spy_trend_col, dash_transp))
        row += 1
        color chop_col = spy_chop > idx_chopC ? bg_R : spy_chop > idx_chopT ? bg_A : bg_G
        f_write(row, "Chop Index", chop_state + " (" + str.tostring(spy_chop, "#.1") + ")", chop_col)
        row += 1
        f_write(row, "HTF Weekly", htfBullish ? "BULLISH" : "BEARISH", htfBullish ? bg_G : bg_R)
        row += 1

    // --- 3. SECTOR BREADTH ---
    if show_brdth
        if dash_orient == "Vertical"
            table.merge_cells(dash, 0, row, 1, row)
            table.cell(dash, 0, row, "SECTOR BREADTH", text_color=col_head_txt, bgcolor=color.new(col_head_bg, dash_transp), text_size=size_str)
            row += 1
        f_write(row, "Breadth Score", brd_str, brd_score > 60 ? bg_G : brd_score < 40 ? bg_R : bg_A)
        row += 1
        string p_txt = "Rp: " + str.tostring(math.round(rip_c)) + " | Tu: " + str.tostring(math.round(trn_c)) + " | Tp: " + str.tostring(math.round(top_c)) + " | Cr: " + str.tostring(math.round(crs_c))
        f_write(row, "Phase Counts", p_txt, bg_N)
        row += 1
        f_write(row, "Breadth Thrust", breadth_thrust ? "YES" : "NO (" + str.tostring(bars_since_thrust) + " ago)", breadth_thrust ? bg_G : bg_N)
        row += 1
        f_write(row, "Liquidity (TNX)", liquidity_stress ? "TIGHT" : "OK", liquidity_stress ? bg_R : bg_G)
        row += 1

    // --- 4. FACTOR REGIME ---
    if show_regime
        if dash_orient == "Vertical"
            table.merge_cells(dash, 0, row, 1, row)
            table.cell(dash, 0, row, "FACTOR REGIME", text_color=col_head_txt, bgcolor=color.new(col_head_bg, dash_transp), text_size=size_str)
            row += 1
        f_write(row, "Risk State", risk_on ? "RISK ON" : "RISK OFF", risk_on ? bg_G : bg_R)
        row += 1
        string reg_txt = g_locs > infla and g_locs > defla ? "GOLDILOCKS" : refla > infla and refla > defla ? "REFLATION" : infla > defla ? "INFLATION" : "DEFLATION"
        f_write(row, "Leading Regime", reg_txt, risk_on ? bg_G : bg_R)
        row += 1
        f_write(row, "Regime %", reg_pct_str, bg_N)
        row += 1

    // --- 5. IMPLIED CORRELATION ---
    if show_implc
        if dash_orient == "Vertical"
            table.merge_cells(dash, 0, row, 1, row)
            table.cell(dash, 0, row, "IMPLIED CORRELATION", text_color=col_head_txt, bgcolor=color.new(col_head_bg, dash_transp), text_size=size_str)
            row += 1
        f_write(row, "ImplCorr Avg", corr_str, ImplCorrAvg > 0.1 ? bg_G : ImplCorrAvg < -0.1 ? bg_R : bg_N)
        row += 1
        f_write(row, "First Green", first_green ? "YES" : str.tostring(bars_since_green) + " ago", first_green ? bg_G : bg_N)
        row += 1

    if show_mmfi
        if dash_orient == "Vertical"
            table.merge_cells(dash, 0, row, 1, row)
            table.cell(dash, 0, row, "MMFI", text_color=col_head_txt, bgcolor=color.new(col_head_bg, dash_transp), text_size=size_str)
            row += 1
            
        color mmfi_val_col = mmfi_c < 20 ? bg_G : mmfi_c < 40 ? bg_R : mmfi_c < 60 ? bg_A : mmfi_c <= 75 ? bg_G : bg_R
        f_write(row, "MMFI Value", mmfi_str, mmfi_val_col)
        row += 1
        
        color mmfi_zone_col = mmfi_zone == "CAPITULATION" or mmfi_zone == "HEALTHY" ? bg_G : mmfi_zone == "OVERHEATED" or mmfi_zone == "BEARISH" ? bg_R : bg_A
        f_write(row, "MMFI Zone", mmfi_zone, mmfi_zone_col)
        row += 1
        
        string mmfi_ma_ctx = mmfi_c > mmfi_s10 and mmfi_c > mmfi_s50 ? " (>MAs)" : mmfi_c > mmfi_s10 ? " (>10)" : mmfi_c < mmfi_s10 and mmfi_c < mmfi_s50 ? " (<MAs)" : ""
        f_write(row, "MMFI Trend", (mmfi_rising ? "RISING" : "FALLING") + mmfi_ma_ctx, mmfi_rising ? bg_G : bg_R)
        row += 1

    if show_vix
        if dash_orient == "Vertical"
            table.merge_cells(dash, 0, row, 1, row)
            table.cell(dash, 0, row, "VOLATILITY (VIX)", text_color=col_head_txt, bgcolor=color.new(col_head_bg, dash_transp), text_size=size_str)
            row += 1
        f_write(row, "VIX Value", vix_str, vix_c < vix_elev ? bg_G : vix_c > vix_fear ? bg_R : bg_A)
        row += 1
        f_write(row, "VIX Zone", vix_zone, vix_c > vix_extr ? bg_G : vix_c > vix_elev ? bg_R : bg_N)
        row += 1
        bool vix_improving = vix_c < vix_s10
        f_write(row, "VIX vs SMA10", vix_improving ? "BELOW (improving)" : "ABOVE (deteriorating)", vix_improving ? bg_G : bg_R)
        row += 1
        f_write(row, "Hedge Signal", vix_act, vix_c > vix_fear ? bg_R : bg_G)
        row += 1

    if show_vol
        if dash_orient == "Vertical"
            table.merge_cells(dash, 0, row, 1, row)
            table.cell(dash, 0, row, "VOLUME ROTATION", text_color=col_head_txt, bgcolor=color.new(col_head_bg, dash_transp), text_size=size_str)
            row += 1
        f_write(row, "Hot Sectors (W)", str.tostring(hot_total) + " / 27", hot_total > 5 ? bg_G : bg_N)
        row += 1
        f_write(row, "Hot Sectors (D)", hot_d_str, hot_total_D > 2 ? bg_G : bg_N)
        row += 1
        
        string v_str_w = ""
        if array.size(hot_syms) > 0
            for i = 0 to math.min(3, array.size(hot_syms) - 1)
                v_str_w += array.get(hot_syms, i) + " " + str.tostring(array.get(hot_vols, i), "#.1") + "x" + array.get(hot_dirs, i) + " "
        else
            v_str_w := "NONE"
        f_write(row, "Top Hot (W)", v_str_w, bg_N)
        row += 1
        
        string v_str_d = ""
        if array.size(hot_syms_D) > 0
            for i = 0 to math.min(3, array.size(hot_syms_D) - 1)
                v_str_d += array.get(hot_syms_D, i) + " " + str.tostring(array.get(hot_vols_D, i), "#.1") + "x" + array.get(hot_dirs_D, i) + " "
        else
            v_str_d := "NONE"
        f_write(row, "Top Hot (D)", v_str_d, bg_N)
        row += 1

// ==============================================================================
// 12. ALERTS & PLOTS 
// ==============================================================================
alertcondition(breadth_thrust, "Breadth Thrust!", "Breadth thrust detected on Macro Command Center")
alertcondition(action_code != nz(action_code[1]), "Action Zone Changed", "Macro action zone changed")
alertcondition(first_green, "ImplCorr First Green", "Implied correlation turned positive — first green bar")

// Data Window Outputs Only (no visual plots on chart)
plot(composite_score, "Macro Score", display=display.data_window)
plot(action_code, "Action Code", display=display.data_window)
plot(risk_on ? 1 : 0, "Risk", display=display.data_window)
plot(first_green ? 1 : 0, "ImplCorr Green", display=display.data_window)
plot(vix_zone_code, "VIX Zone", display=display.data_window)
plot(brd_score, "Breadth", display=display.data_window)
plot(ImplCorrAvg, "ImplCorr Avg", display=display.data_window)
