//@version=6
indicator("MACRO COMMAND CENTER v2.3", overlay=true, max_labels_count=500)

// ==============================================================================
// 1. GLOBAL SETTINGS & TOGGLES
// ==============================================================================
grp_global = "1. Global Settings"
fixedTF     = input.timeframe("240", "Indicator Timeframe", options=["240", "D", "W"], group=grp_global, tooltip="The core timeframe for the script's math. '240' (4-Hour) or 'D' (Daily) is recommended.")
